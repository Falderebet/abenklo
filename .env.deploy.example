# Copy this file to .env.deploy and fill in your values.
# NEVER commit .env.deploy to git.

# Your Coolify API token
# Dashboard → Profile → API tokens → Create token
COOLIFY_TOKEN=your_api_token_here

# Your app's deploy webhook URL
# Dashboard → Application → Configuration → Webhooks → Deploy Webhook
COOLIFY_WEBHOOK_URL=https://your-coolify.example.com/api/v1/deploy?uuid=YOUR_APP_UUID&force=false
